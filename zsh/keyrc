[ -f $HOME/.cargo/env ] && source $HOME/.cargo/env

export LOGNAME=key
export EDITOR=nvr
export GPG_TTY=$(tty)

[ -z "$(where nvr)" ] && pip3 install neovim-remote

if [ -d ~/Development/box ]; then
  alias box="make -C ~/Development/box enter"
fi

alias vf="git grep --open-files-in-pager=$EDITOR"
alias fd="fdfind"
alias dc="docker compose"
alias codex="$DOTFILES/node_modules/@openai/codex/bin/codex.js"
alias copilot="$DOTFILES/node_modules/@github/copilot/index.js"
